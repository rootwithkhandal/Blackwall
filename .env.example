# Splunk HEC (optional)
SPLUNK_HEC_URL=https://splunk.example.com:8088/services/collector/event
SPLUNK_HEC_TOKEN=your-hec-token-here

# Wazuh (optional)
WAZUH_SOCKET_PATH=/var/ossec/queue/sockets/queue

# Threat Intel (optional)
ABUSEIPDB_KEY=your-abuseipdb-api-key
SHODAN_KEY=your-shodan-api-key
VIRUSTOTAL_KEY=your-virustotal-api-key

# Webhook Alerts for Spikes (optional, Discord or Slack)
WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

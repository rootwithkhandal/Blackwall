# ── Splunk HEC (leave blank to disable) ────────────────────────────────────────
SPLUNK_HEC_URL=https://splunk.example.com:8088/services/collector/event
SPLUNK_HEC_TOKEN=

# ── Wazuh agent socket (leave blank to disable) ───────────────────────────────
WAZUH_SOCKET_PATH=/var/ossec/queue/sockets/queue
